# ============================================================
# astro-horoscope-backend — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# Application
APP_ENV=development          # development | staging | production
DEFAULT_LANGUAGE=ro          # ro | en
DEFAULT_TIMEZONE=Europe/Bucharest
PORT=8000

# Geolocation defaults (used for astrological calculations)
DEFAULT_LAT=46.7712          # Latitude
DEFAULT_LNG=23.6236          # Longitude

# AI / LLM provider (add your key here — NEVER commit the real value)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# CORS (comma-separated origins for production)
# ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Rate limiting (optional)
# RATE_LIMIT_PER_MINUTE=10
